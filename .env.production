# Configuración de producción para Azure
PRODUCTION=true
NODE_ENV=production
PYTHONPATH=./backend

# Azure OpenAI (usar valores del archivo .env del backend)
AZURE_OPENAI_API_KEY=<CHANGE_ME>
AZURE_OPENAI_ENDPOINT=<CHANGE_ME>
AZURE_OPENAI_DEPLOYMENT=<CHANGE_ME>
AZURE_OPENAI_API_VERSION=<CHANGE_ME>

# Base de datos PostgreSQL (si está configurada)
DATABASE_URL=<CHANGE_ME>

# Configuración del servidor Azure
PORT=8080
HOST=0.0.0.0
