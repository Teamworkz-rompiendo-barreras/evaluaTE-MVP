# .swaignore
# Archivos y carpetas ignorados por Azure Static Web Apps

# Carpeta de desarrollo frontend
nuevo-frontend/node_modules
nuevo-frontend/dist
nuevo-frontend/.vite
nuevo-frontend/.svelte-kit
nuevo-frontend/.next
nuevo-frontend/.nuxt
nuevo-frontend/.angular
nuevo-frontend/.cache
nuevo-frontend/.temp
nuevo-frontend/tmp
nuevo-frontend/public/scenes/__pycache__
nuevo-frontend/src/types/*.d.ts
nuevo-frontend/vitest.config.ts
nuevo-frontend/cypress.config.ts
nuevo-frontend/.eslintcache
nuevo-frontend/.prettierrc.js
nuevo-frontend/.eslintrc.js
nuevo-frontend/.browserslistrc
nuevo-frontend/tailwind.config.ts
nuevo-frontend/postcss.config.ts
nuevo-frontend/package-lock.json
nuevo-frontend/yarn.lock
nuevo-frontend/pnpm-lock.yaml

# Archivos sensibles o temporales
*.log
*.env.local
*.env.development*
*.env.test*
*.env.development.local
*.env.production.local
*.env.staging*
*.env.build*

# Archivos generados por herramientas
coverage/
__pycache__
*.pyc
*.db
.DS_Store
Thumbs.db
desktop.ini
.git
.husky
.prettierignore
.eslintignore