# Azure OpenAI Configuration
# Copia este archivo como .env y completa con tus valores reales

# API Key de Azure OpenAI
AZURE_OPENAI_API_KEY=4ku7UcKVerAXcTXurf4Of1aDGC5w5UreekGaLuxbsnuxOdZe48NdJQQJ99BGACR0EKYXJ3w3AAABACOGiqbl

# Endpoint de Azure OpenAI (debe terminar en .openai.azure.com)
AZURE_OPENAI_ENDPOINT=https://teamworkzevaluate-openai.openai.azure.com/

# Nombre del deployment (el que crees en Azure OpenAI)
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# Versión de la API (usar la más reciente)
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Configuración del backend
PORT=8080
HOST=0.0.0.0

# Configuración de CORS (opcional)
ALLOWED_ORIGINS=http://localhost:3005,http://localhost:3006,http://localhost:5173 