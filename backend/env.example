# Azure OpenAI Configuration
# La aplicación requiere Azure OpenAI para generar informes personalizados con IA
# Copia este archivo como .env y completa con tus valores reales

# API Key de Azure OpenAI (REQUERIDO)
AZURE_OPENAI_API_KEY=tu_api_key_aqui

# Endpoint de Azure OpenAI (debe terminar en .openai.azure.com) (REQUERIDO)
AZURE_OPENAI_ENDPOINT=https://tu-recurso.openai.azure.com

# Nombre del deployment (REQUERIDO)
# Usar uno de estos deployments estándar que existen por defecto:
# - gpt-35-turbo (más rápido, más económico)
# - gpt-4 (más potente, más costoso)
# - gpt-4o (más reciente, balanceado)
AZURE_OPENAI_DEPLOYMENT=gpt-35-turbo

# Versión de la API (usar la más reciente)
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Configuración del backend
PORT=8000
HOST=0.0.0.0

# Configuración de CORS (opcional)
ALLOWED_ORIGINS=http://localhost:3005,http://localhost:3006,http://localhost:5173

# INSTRUCCIONES PARA CONFIGURAR AZURE OPENAI:
# 1. Ve a https://portal.azure.com
# 2. Crea un recurso "Azure OpenAI"
# 3. Una vez creado, ve a "Keys and Endpoint"
# 4. Copia la "Key 1" como AZURE_OPENAI_API_KEY
# 5. Copia el "Endpoint" como AZURE_OPENAI_ENDPOINT
# 6. Ve a "Model deployments" y crea un deployment con uno de los modelos disponibles
# 7. Usa el nombre del deployment como AZURE_OPENAI_DEPLOYMENT 