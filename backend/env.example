# =============================================================================
# CONFIGURACIÓN DE ENTORNO PARA EVALUATE BACKEND
# =============================================================================
# IMPORTANTE: Copia este archivo como .env y completa con tus valores reales
# La aplicación funcionará en modo básico sin Azure, pero con funcionalidad limitada

# =============================================================================
# AZURE OPENAI (REQUERIDO para funcionalidad completa de IA)
# =============================================================================
# API Key de Azure OpenAI
AZURE_OPENAI_API_KEY=tu_api_key_aqui

# Endpoint de Azure OpenAI (debe terminar en .openai.azure.com)
AZURE_OPENAI_ENDPOINT=https://tu-recurso.openai.azure.com

# Nombre del deployment (usar uno de estos modelos estándar):
# - gpt-35-turbo (más rápido, más económico)
# - gpt-4 (más potente, más costoso)
# - gpt-4o (más reciente, balanceado)
AZURE_OPENAI_DEPLOYMENT=gpt-35-turbo

# Versión de la API (usar la más reciente)
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# =============================================================================
# AZURE AI DOCUMENT INTELLIGENCE (OPCIONAL pero RECOMENDADO)
# =============================================================================
# Mejora significativamente la extracción de información de CVs
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://tu-recurso-document-intelligence.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=tu_document_intelligence_key_aqui
AZURE_DI_MODEL_ID=prebuilt-document

# =============================================================================
# AZURE STORAGE (OPCIONAL)
# =============================================================================
# Para almacenamiento de archivos temporales
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=tu-cuenta;AccountKey=tu-clave;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=cv-uploads

# =============================================================================
# CONFIGURACIÓN DEL BACKEND
# =============================================================================
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=INFO

# =============================================================================
# CONFIGURACIÓN DE CORS
# =============================================================================
# Orígenes permitidos (separados por comas)
ALLOWED_ORIGINS=http://localhost:3005,http://localhost:3006,http://localhost:5173,http://localhost:8080

# =============================================================================
# CONFIGURACIÓN DE EMAIL (OPCIONAL)
# =============================================================================
# Para notificaciones de feedback
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=tu_contraseña_de_aplicacion
ADMIN_EMAIL=ester@teamworkz.co

# =============================================================================
# INSTRUCCIONES DE CONFIGURACIÓN
# =============================================================================
# 1. COPIA ESTE ARCHIVO COMO .env:
#    cp env.example .env
#
# 2. CONFIGURA AZURE OPENAI:
#    - Ve a https://portal.azure.com
#    - Crea un recurso "Azure OpenAI"
#    - Ve a "Keys and Endpoint"
#    - Copia la "Key 1" como AZURE_OPENAI_API_KEY
#    - Copia el "Endpoint" como AZURE_OPENAI_ENDPOINT
#    - Ve a "Model deployments" y crea un deployment
#    - Usa el nombre del deployment como AZURE_OPENAI_DEPLOYMENT
#
# 3. CONFIGURA AZURE DOCUMENT INTELLIGENCE (OPCIONAL):
#    - Crea un recurso "Azure AI Document Intelligence"
#    - Copia endpoint y key a las variables correspondientes
#
# 4. REINICIA EL BACKEND después de configurar las variables
#
# NOTA: Sin Azure OpenAI, la aplicación funcionará en modo básico
# pero no podrá generar informes personalizados con IA 