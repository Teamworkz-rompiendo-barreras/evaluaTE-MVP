{
  "compilerOptions": {
    /* Visit https://aka.ms/tsconfig to read more about this file */

    "target": "es2020",                                  /* Set ECMAScript language version for emitted JavaScript. */
    "module": "commonjs",                               /* Specify module code generation. */
    "rootDir": "./",                                   /* Root folder within source files. */
    "outDir": "./dist",                                /* Output folder for emitted files. */
    "strict": true,                                      /* Enable all strict type-checking options. */
    "esModuleInterop": true,                             /* Emit additional JS to ease support for importing CommonJS modules. */
    "forceConsistentCasingInFileNames": true,            /* Ensure correct casing in imports. */
    "skipLibCheck": true                                 /* Skip type checking all .d.ts files. */
  },
  "include": ["index.ts"]                               /* Include the main entry point */
}
