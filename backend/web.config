<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <!-- Configuración para Python/FastAPI -->
      <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>
    
    <httpPlatform processPath="%home%\site\wwwroot\venv\Scripts\python.exe"
                  arguments="%home%\site\wwwroot\azure_startup.py"
                  stdoutLogEnabled="true"
                  stdoutLogFile="%home%\LogFiles\stdout"
                  startupTimeLimit="120">
      <environmentVariables>
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="PYTHONPATH" value="%home%\site\wwwroot" />
        <environmentVariable name="HOST" value="0.0.0.0" />
        <environmentVariable name="PRODUCTION" value="true" />
      </environmentVariables>
    </httpPlatform>
    
    <rewrite>
      <rules>
        <!-- Redirigir todas las peticiones a FastAPI -->
        <rule name="FastAPI" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="startup.py" />
        </rule>
      </rules>
    </rewrite>
    
    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin"/>
        </hiddenSegments>
      </requestFiltering>
    </security>
    
    <httpErrors existingResponse="PassThrough" />
  </system.webServer>
</configuration> 