{
    "installCommand": "cd nuevo-frontend && npm install --legacy-peer-deps --include=dev",
    "buildCommand": "cd nuevo-frontend && CI=false NODE_OPTIONS=--max-old-space-size=4096 npm run build",
    "outputDirectory": "nuevo-frontend/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "api/index.py"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}