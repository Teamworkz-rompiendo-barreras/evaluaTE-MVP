{
    "buildCommand": "cd nuevo-frontend && corepack enable && pnpm install --no-frozen-lockfile && pnpm run build",
    "outputDirectory": "nuevo-frontend/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}