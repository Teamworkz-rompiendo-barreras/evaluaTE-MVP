{
    "buildCommand": "cd nuevo-frontend && npm install && npm run build",
    "outputDirectory": "nuevo-frontend/dist",
    "rewrites": [
        {
            "source": "/api/health",
            "destination": "/api/index.py"
        },
        {
            "source": "/api/analyze",
            "destination": "/api/index.py"
        },
        {
            "source": "/api/report/generate",
            "destination": "/api/index.py"
        },
        {
            "source": "/api/debug/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}