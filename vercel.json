{
  "buildCommand": "cd nuevo-frontend && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "nuevo-frontend/dist",
  "installCommand": "pip install -r requirements.txt",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
